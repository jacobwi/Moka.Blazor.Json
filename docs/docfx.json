{
  "metadata": [
    {
      "src": [
        {
          "files": [
            "src/Moka.Blazor.Json/*.csproj",
            "src/Moka.Blazor.Json.Abstractions/*.csproj"
          ],
          "src": "../"
        }
      ],
      "dest": "api",
      "properties": {
        "TargetFramework": "net9.0"
      },
      "includePrivateMembers": false,
      "disableGitFeatures": false,
      "disableDefaultFilter": false
    }
  ],
  "build": {
    "content": [
      {
        "files": [
          "api/**.yml",
          "api/index.md"
        ]
      },
      {
        "files": [
          "articles/**.md",
          "articles/**/toc.yml",
          "toc.yml",
          "*.md"
        ]
      }
    ],
    "resource": [
      {
        "files": [
          "images/**"
        ]
      }
    ],
    "output": "_site",
    "template": [
      "default",
      "modern"
    ],
    "globalMetadata": {
      "_appTitle": "Moka.Blazor.Json",
      "_appName": "Moka.Blazor.Json",
      "_appFooter": "Moka.Blazor.Json - MIT License",
      "_enableSearch": true,
      "_enableNewTab": true
    }
  }
}
