@namespace Moka.Blazor.Json.Components

<HeadContent>
	<link href="_content/Moka.Blazor.Json/css/moka-json.css" rel="stylesheet"/>
</HeadContent>

<div class="moka-json-viewer @(WordWrap ? "moka-json-viewer--word-wrap" : "")" @ref="_viewerRef" style="@ComputedStyle" @attributes="AdditionalAttributes"
     data-moka-json-theme="@ThemeAttribute"
     @onkeydown="HandleKeyDown">

	@if (_toastMessage is not null)
	{
		<div class="moka-json-toast" @onclick="DismissToast">
			<span class="moka-json-toast-text">@_toastMessage</span>
			<button class="moka-json-toast-dismiss" title="Dismiss">&times;</button>
		</div>
	}

	@if (_errorMessage is not null)
	{
		<div class="moka-json-error">
			<span class="moka-json-error-title">Error</span>
			<span class="moka-json-error-details">@_errorMessage</span>
		</div>
	}
	else if (!_isLoaded && _isLoading)
	{
		<div class="moka-json-loading">
			<span class="moka-json-busy-spinner"></span>
			Loading...
		</div>
	}
	else if (_isLoaded)
	{
		@if (_isBusy)
		{
			<div class="moka-json-busy-overlay">
				<span class="moka-json-busy-spinner"></span>
				<span class="moka-json-busy-text">@_busyMessage</span>
			</div>
		}

		@if (ShowToolbar)
		{
			<div style="position: relative;">
				<MokaJsonToolbar OnSearchToggle="ToggleSearch"
				                 OnExpandAll="HandleExpandAll"
				                 OnCollapseAll="HandleCollapseAll"
				                 OnFormatToggle="HandleFormatToggle"
				                 OnCopyAll="HandleCopyAll"
				                 OnExport="HandleExport"
				                 IsFormatted="_isFormatted"
				                 ToolbarExtra="ToolbarExtra"
				                 IsBusy="_isBusy"
				                 ToolbarMode="EffectiveToolbarMode"
				                 OnSettingsToggle="ToggleSettings"
				                 ShowSettingsButton="EffectiveShowSettingsButton"/>

				@if (_showSettings)
				{
					<MokaJsonSettingsPanel IsVisible="true"
					                       Left="_settingsLeft"
					                       Top="_settingsTop"
					                       OnDismiss="DismissSettings"
					                       Theme="Theme"
					                       ThemeChanged="HandleSettingsThemeChanged"
					                       ToolbarMode="EffectiveToolbarMode"
					                       ToolbarModeChanged="HandleSettingsToolbarModeChanged"
					                       ToggleStyle="ToggleStyle"
					                       ToggleStyleChanged="HandleSettingsToggleStyleChanged"
					                       ToggleSize="ToggleSize"
					                       ToggleSizeChanged="HandleSettingsToggleSizeChanged"
					                       ShowLineNumbers="ShowLineNumbers"
					                       ShowLineNumbersChanged="HandleSettingsShowLineNumbersChanged"
					                       WordWrap="WordWrap"
					                       WordWrapChanged="HandleSettingsWordWrapChanged"
					                       ShowBreadcrumb="ShowBreadcrumb"
					                       ShowBreadcrumbChanged="HandleSettingsShowBreadcrumbChanged"
					                       ShowBottomBar="ShowBottomBar"
					                       ShowBottomBarChanged="HandleSettingsShowBottomBarChanged"
					                       ShowChildCount="ShowChildCount"
					                       ShowChildCountChanged="HandleSettingsShowChildCountChanged"
					                       MaxDepthExpanded="MaxDepthExpanded"
					                       MaxDepthExpandedChanged="HandleSettingsMaxDepthChanged"
					                       CollapseMode="CollapseMode"
					                       CollapseModeChanged="HandleSettingsCollapseModeChanged"
					                       ReadOnly="ReadOnly"
					                       ReadOnlyChanged="HandleSettingsReadOnlyChanged"
					                       SearchCaseSensitive="_searchCaseSensitive"
					                       SearchCaseSensitiveChanged="HandleSettingsSearchCaseSensitiveChanged"
					                       SearchUseRegex="_searchUseRegex"
					                       SearchUseRegexChanged="HandleSettingsSearchUseRegexChanged"/>
				}
			</div>
		}

		@if (_showSearch)
		{
			<MokaJsonSearchOverlay Query="@_searchQuery"
			                       MatchCount="@_searchEngine.MatchCount"
			                       ActiveMatchIndex="@_searchEngine.ActiveMatchIndex"
			                       CaseSensitive="@_searchCaseSensitive"
			                       UseRegex="@_searchUseRegex"
			                       OnQueryChanged="HandleSearchQueryChanged"
			                       OnNext="HandleSearchNext"
			                       OnPrevious="HandleSearchPrevious"
			                       OnClose="ToggleSearch"
			                       OnCaseSensitiveChanged="HandleCaseSensitiveChanged"
			                       OnRegexChanged="HandleRegexChanged"/>
		}

		@if (ShowBreadcrumb && (SelectedPath is not null || _scopedPath is not null) && _documentSource is not null)
		{
			<MokaJsonBreadcrumb Path="@(SelectedPath ?? _scopedPath)"
			                    RootValueKind="@_documentSource.RootValueKind"
			                    OnNavigate="HandleBreadcrumbNavigate"/>
		}

		<MokaJsonTreeViewport Nodes="@_flatNodes"
		                      SelectedPath="@SelectedPath"
		                      ShowLineNumbers="ShowLineNumbers"
		                      ShowChildCount="ShowChildCount"
		                      ToggleStyle="ToggleStyle"
		                      ToggleSize="ToggleSize"
		                      ReadOnly="EffectiveReadOnly"
		                      EditState="@_activeEdit"
		                      OnToggle="HandleToggle"
		                      OnSelect="HandleSelect"
		                      OnContextMenu="HandleContextMenuRequest"
		                      OnDoubleClick="HandleDoubleClick"
		                      OnEditCommit="HandleEditCommit"
		                      OnEditCancel="HandleEditCancel"/>

		@if (ShowBottomBar)
		{
			<MokaJsonBottomBar DocumentSize="@_documentSize"
			                   NodeCount="@_nodeCount"
			                   CurrentDepth="@_selectedDepth"
			                   MaxDepth="@_maxDepth"
			                   ParseTimeMs="@_parseTimeMs"
			                   SelectedPath="@SelectedPath"
			                   IsValid="@_isValid"
			                   ValidationError="@_validationError"
			                   IsLazyMode="@_isLazyMode"/>
		}
	}
</div>

@* Render context menu OUTSIDE the viewer div so overflow:hidden doesn't clip it *@
<MokaJsonContextMenu @ref="_contextMenu"
                     Actions="@_allContextActions"
                     IsVisible="@_contextMenuVisible"
                     NodeContext="@_contextMenuNodeContext"
                     OnDismiss="DismissContextMenu"/>
