@page "/"
@using Moka.Blazor.Json.AI.Components
@using Moka.Blazor.Json.Diagnostics.Components

<h1>Moka.Blazor.Json Demo</h1>

<!-- ====== 1. Toolbar Modes ====== -->
<h2>1. Toolbar Modes</h2>
<p>Switch between <strong>Text</strong>, <strong>Icon</strong>, and <strong>Icon + Text</strong> toolbar layouts. Right-click any node to see context menu with icons.</p>
<div style="display: flex; gap: 6px; align-items: center; margin-bottom: 12px;">
	<span style="font-size: 13px; color: #666;">Toolbar mode:</span>
	<button @onclick="@(() => _demoToolbarMode = MokaJsonToolbarMode.Text)"
	        style="@ToolbarBtnStyle(_demoToolbarMode == MokaJsonToolbarMode.Text)">
		Text
	</button>
	<button @onclick="@(() => _demoToolbarMode = MokaJsonToolbarMode.Icon)"
	        style="@ToolbarBtnStyle(_demoToolbarMode == MokaJsonToolbarMode.Icon)">
		Icon
	</button>
	<button @onclick="@(() => _demoToolbarMode = MokaJsonToolbarMode.IconAndText)"
	        style="@ToolbarBtnStyle(_demoToolbarMode == MokaJsonToolbarMode.IconAndText)">
		Icon + Text
	</button>
</div>
<MokaJsonViewer Json="@_sampleJson" Height="500px" ToolbarMode="@_demoToolbarMode"/>

<!-- ====== 2. Theme Switcher ====== -->
<h2>2. Theme</h2>
<p>Switch between <strong>Light</strong>, <strong>Dark</strong>, and <strong>Auto</strong> (follows OS preference).</p>
<div style="display: flex; gap: 6px; align-items: center; margin-bottom: 12px;">
	<span style="font-size: 13px; color: #666;">Theme:</span>
	<button @onclick="@(() => _demoTheme = MokaJsonTheme.Light)"
	        style="@ToolbarBtnStyle(_demoTheme == MokaJsonTheme.Light)">
		Light
	</button>
	<button @onclick="@(() => _demoTheme = MokaJsonTheme.Dark)"
	        style="@ToolbarBtnStyle(_demoTheme == MokaJsonTheme.Dark)">
		Dark
	</button>
	<button @onclick="@(() => _demoTheme = MokaJsonTheme.Auto)"
	        style="@ToolbarBtnStyle(_demoTheme == MokaJsonTheme.Auto)">
		Auto
	</button>
</div>
<MokaJsonViewer Json="@_sampleJson" Theme="@_demoTheme" Height="400px"/>

<!-- ====== 3. Minimal ====== -->
<h2>3. Minimal (No Chrome)</h2>
<p>Toolbar, bottom bar, and breadcrumb all hidden. Collapsed to depth 1.</p>
<MokaJsonViewer Json="@_sampleJson" ShowToolbar="false" ShowBottomBar="false" ShowBreadcrumb="false" Height="250px" MaxDepthExpanded="1"/>

<!-- ====== 4. With Line Numbers ====== -->
<h2>4. With Line Numbers</h2>
<p>Code-editor style gutter with line numbers enabled.</p>
<MokaJsonViewer Json="@_sampleJson" ShowLineNumbers="true" Height="400px"/>

<!-- ====== 5. Deep Nesting ====== -->
<h2>5. Deeply Nested JSON</h2>
<p>10 levels deep — tests indentation, expand/collapse, and breadcrumb navigation.</p>
<MokaJsonViewer Json="@_deepNestedJson" Height="500px" MaxDepthExpanded="3" ShowLineNumbers="true"/>

<!-- ====== 6. Large Array ====== -->
<h2>6. Large Array (10,000 items)</h2>
<p>Virtualized rendering of a flat array with 10k numeric entries.</p>
<MokaJsonViewer Json="@_largeArrayJson" Height="400px" MaxDepthExpanded="1"/>

<!-- ====== 7. Mixed Types ====== -->
<h2>7. Mixed Value Types</h2>
<p>Showcases all JSON value types: strings, numbers, booleans, null, arrays, objects.</p>
<MokaJsonViewer Json="@_mixedTypesJson" Height="500px" MaxDepthExpanded="5"/>

<!-- ====== 8. API Response ====== -->
<h2>8. API Response (Realistic)</h2>
<p>A realistic paginated API response with metadata, links, and nested resources.</p>
<MokaJsonViewer Json="@_apiResponseJson" Height="500px" Theme="MokaJsonTheme.Dark" ShowLineNumbers="true"/>

<!-- ====== 9. GeoJSON ====== -->
<h2>9. GeoJSON FeatureCollection</h2>
<p>Geospatial data with coordinate arrays and properties.</p>
<MokaJsonViewer Json="@_geoJson" Height="500px"/>

<!-- ====== 10. Custom Context Menu Actions ====== -->
<h2>10. Custom Context Menu Actions</h2>
<p>Right-click nodes to see context-aware actions: "Open URL" appears on URLs, "Copy Email" on email fields, "Show Type Info" on any node.</p>
<MokaJsonViewer Json="@_contextMenuDemoJson" Height="500px" ContextMenuActions="@_customContextActions"/>
@if (_lastActionMessage is not null)
{
	<div style="margin-top: 8px; padding: 8px 12px; background: #e8f5e9; border-radius: 4px; font-family: monospace; font-size: 13px;">
		@_lastActionMessage
	</div>
}

<!-- ====== 11. Edit Mode ====== -->
<h2>11. Edit Mode</h2>
<p>Double-click any value to edit inline. Right-click for add/delete/rename actions. Ctrl+Z/Y for undo/redo.</p>
<MokaJsonViewer @bind-Json="_editDemoJson" ReadOnly="false" Height="500px" ShowLineNumbers="true"/>
@if (_editDemoJson is not null)
{
	<details style="margin-top: 8px;">
		<summary style="cursor: pointer; font-family: monospace; font-size: 13px; color: #666;">Current JSON output</summary>
		<pre style="margin-top: 4px; padding: 8px; background: #f5f5f5; border-radius: 4px; font-size: 12px; max-height: 200px; overflow: auto;">@_editDemoJson</pre>
	</details>
}

<!-- ====== 12. Stress Test — Lazy Parsing ====== -->
<h2>12. Stress Test — Lazy Parsing</h2>
<p>
	Generate a large JSON document to test lazy/indexed parsing.
	Documents above 50 MB automatically use <strong>Lazy Mode</strong>: only a structural index is built upfront,
	and subtrees are parsed on demand as you expand them. Editing is disabled in lazy mode.
</p>
<div style="display: flex; gap: 8px; align-items: center; margin-bottom: 12px;">
	<label>Target size (MB):</label>
	<input type="number" @bind="_targetSizeMb" min="1" max="1000" style="width: 100px; padding: 4px 8px;"/>
	<button @onclick="GenerateStressTest" disabled="@_isGenerating"
	        style="padding: 6px 16px; cursor: pointer;">
		@if (_isGenerating)
		{
			<span>Generating... @_generationProgress</span>
		}
		else
		{
			<span>Generate</span>
		}
	</button>
	@if (_stressTestStream is not null)
	{
		<span style="color: #666; font-size: 12px;">
			@FormatBytes(_stressTestSize) on disk |
			@_stressTestNodeCount.ToString("N0") estimated nodes |
			Generated in @_stressTestGenTime
		</span>
		@if (_stressTestSize > 50 * 1024 * 1024)
		{
			<span style="display: inline-block; background: #0000ff; color: #fff; padding: 1px 8px; border-radius: 3px; font-size: 11px; font-weight: 600;">
				Lazy Mode Active
			</span>
		}
	}
</div>

@if (_stressTestStream is not null)
{
	<div style="display: flex; align-items: center; gap: 6px; margin-bottom: 8px;">
		<label style="display: flex; align-items: center; gap: 4px; font-size: 13px; cursor: pointer;">
			<input type="checkbox" @bind="_showDiagnostics"/>
			Show Diagnostics Overlay
		</label>
		<span style="color: #999; font-size: 11px;">(Moka.Blazor.Json.Diagnostics)</span>
	</div>
	<div style="position: relative;">
		<MokaJsonViewer @ref="_stressTestViewer" JsonStream="@_stressTestStream" Height="600px" MaxDepthExpanded="1" ShowLineNumbers="true"/>
		<MokaJsonDebugOverlay Viewer="_stressTestViewer" Enabled="_showDiagnostics"/>
	</div>
}

<!-- ====== AI Assistant ====== -->
<h2>13. AI Assistant</h2>
<p>
	Ask natural language questions about your JSON data. Powered by a local LLM via <strong>LM Studio</strong>, <strong>Ollama</strong>, or any <code>IChatClient</code> provider.
	Use the quick actions or type a question. Click <strong>Stop</strong> to cancel mid-stream.
</p>
<p style="font-size: 12px; color: #888;">Requires <a href="https://lmstudio.ai" target="_blank">LM Studio</a> running locally with a model loaded (e.g., Qwen2.5-3B or Phi-3.5-mini).</p>
<MokaJsonViewer @ref="_aiDemoViewer" Json="@_sampleJson" Height="400px" ContextMenuActions="_aiContextActions"/>
<MokaJsonAiPanel @ref="_aiPanel" Viewer="_aiDemoViewer" MessagesHeight="400px"/>

<!-- ====== Scoped AI Context ====== -->
<h2>14. Scoped AI Context</h2>
<p>
	Two separate JSON objects displayed side by side. Click <strong>Scope to this</strong> to focus the AI panel on just that object's data.
	The AI only sees the scoped context — perfect for comparing or analyzing specific datasets without the full document.
</p>
<p style="font-size: 12px; color: #888;">
	Right-click any node and choose <strong>Ask AI</strong> to auto-scope to that subtree. Or use the buttons below to scope the entire viewer.
</p>
<div style="display: flex; gap: 16px; margin-bottom: 12px;">
	<div style="flex: 1;">
		<div style="display: flex; align-items: center; gap: 8px; margin-bottom: 8px;">
			<h4 style="margin: 0;">🧑 Customer Record</h4>
			<button @onclick="ToggleCustomerScope"
			        disabled="@(_scopedPanel is null || _scopedPanel.IsSending)"
			        style="@ScopeBtnStyle(_customerScoped)">
				@(_customerScoped ? "✓ Scoped" : "Scope to this")
			</button>
		</div>
		<MokaJsonViewer @ref="_scopedViewer1" Json="@_customerJson" Height="300px"
		                Theme="MokaJsonTheme.Dark" MaxDepthExpanded="3"
		                ContextMenuActions="_scopedContextActions"/>
	</div>
	<div style="flex: 1;">
		<div style="display: flex; align-items: center; gap: 8px; margin-bottom: 8px;">
			<h4 style="margin: 0;">📦 Order Record</h4>
			<button @onclick="ToggleOrderScope"
			        disabled="@(_scopedPanel is null || _scopedPanel.IsSending)"
			        style="@ScopeBtnStyle(_orderScoped)">
				@(_orderScoped ? "✓ Scoped" : "Scope to this")
			</button>
		</div>
		<MokaJsonViewer @ref="_scopedViewer2" Json="@_orderJson" Height="300px"
		                Theme="MokaJsonTheme.Dark" MaxDepthExpanded="3"
		                ContextMenuActions="_scopedContextActions"/>
	</div>
</div>
<div style="display: flex; align-items: center; gap: 8px; margin-bottom: 8px;">
	<span style="font-size: 13px; color: #888;">
		Active scope:
		@if (_customerScoped && _orderScoped)
		{
			<strong style="color: #0ea5e9;">Customer + Order</strong>
		}
		else if (_customerScoped)
		{
			<strong style="color: #0ea5e9;">Customer</strong>
		}
		else if (_orderScoped)
		{
			<strong style="color: #0ea5e9;">Order</strong>
		}
		else
		{
			<strong style="color: #999;">None (full document)</strong>
		}
	</span>
	@if (_customerScoped || _orderScoped)
	{
		<button @onclick="ClearScopeDemo" style="padding: 2px 10px; font-size: 12px; cursor: pointer; border: 1px solid #ddd; border-radius: 4px; background: #fff;">
			Clear all
		</button>
	}
</div>
<MokaJsonAiPanel @ref="_scopedPanel" Viewer="_activeViewer" MessagesHeight="350px"/>
